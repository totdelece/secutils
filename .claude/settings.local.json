{
  "permissions": {
    "allow": [
      "Bash(npm --version)",
      "Bash(git --version)",
      "Bash(where node *)",
      "PowerShell(winget *)",
      "Bash([ -f \"$HOME/AppData/Roaming/nvm/nodejs/node.exe\" ])",
      "Read(//c/Program Files/nodejs/**)",
      "Bash(\"/c/Program Files/nodejs/node.exe\" --version)",
      "Bash(\"/c/Program Files/nodejs/npm.cmd\" --version)",
      "Bash(export PATH=\"/c/Program Files/nodejs:$PATH\")",
      "Bash(npx --yes create-next-app@latest . --typescript --tailwind --app --eslint --src-dir --import-alias \"@/*\" --use-npm --turbopack)",
      "Bash(npm run *)",
      "Bash(echo \"Dev server PID: $!\")",
      "Bash(disown)",
      "Bash(grep -q -E \"Ready|ready|error|Error\" /tmp/dev.log)",
      "Read(//tmp/**)",
      "Bash(curl -s -o /tmp/home.html -w \"HOME: %{http_code}\\\\n\" http://localhost:3000/)",
      "Bash(curl -s -o /tmp/pwd.html -w \"PWGEN: %{http_code}\\\\n\" http://localhost:3000/tools/password-generator)",
      "Bash(curl -s http://localhost:3000/)",
      "Bash(curl -s -o /tmp/pwd.html -w \"PWGEN status: %{http_code}\\\\n\" http://localhost:3000/tools/password-generator)",
      "Bash(curl -s -o /tmp/pwd.html -w \"%{http_code}\" http://localhost:3000/tools/password-generator)"
    ]
  }
}
